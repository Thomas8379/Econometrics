# Claude Code local settings
.claude/settings.local.json

# Python cache
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.coverage
htmlcov/

# Stata temporary files
*.stswp
*.ster
*.smcl

# OS files
.DS_Store
Thumbs.db

# Log files
*.log

# Data lake — raw binary files are not tracked
data_lake/raw/**
# Exceptions: keep the manifest and directory placeholder in version control
!data_lake/raw/.gitkeep
!data_lake/raw/**/manifest.json

# Curated Parquet files (usually too large to commit)
data_lake/curated/**
# Exception: keep directory placeholder in version control
!data_lake/curated/.gitkeep
