# Claude Code local settings
.claude/settings.local.json

# Python cache
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.coverage
htmlcov/

# Stata temporary files
*.stswp
*.ster
*.smcl

# OS files
.DS_Store
Thumbs.db

# Log files
*.log

# Data lake — raw binary files are not tracked.
# We use data_lake/raw/*/* (not data_lake/raw/**) so that subdirectory entries
# themselves are NOT excluded — git must be able to traverse into them to apply
# the manifest/README exceptions below.
data_lake/raw/*/*
data_lake/raw/*/**
# Exceptions: keep the manifest, README, and directory placeholder in version control
!data_lake/raw/.gitkeep
!data_lake/raw/*/manifest.json
!data_lake/raw/*/README.md

# Curated Parquet files (usually too large to commit)
data_lake/curated/**
# Exception: keep directory placeholder in version control
!data_lake/curated/.gitkeep
